# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=PotatoAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:4200

# ─── Error & Logging ──────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=chatgpt_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Docker service vars (used by the postgres container, not Laravel)
POSTGRES_DB=chatgpt_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=chatgpt_db

# Docker service var (used by the mongodb container, not Laravel)
MONGO_INITDB_DATABASE=chatgpt_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Cache / Queue / Session ──────────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Broadcasting (Laravel Reverb) ────────────────────────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=chatgpt-app
REVERB_APP_KEY=chatgpt-key
REVERB_APP_SECRET=chatgpt-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=6001
REVERB_SCHEME=http

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@potatoaihub.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_SUPPORT_ADDRESS="support@potatoaihub.com"

# ─── Storage ──────────────────────────────────────────────────────────────────
# Laravel default filesystem disk
FILESYSTEM_DISK=s3
# Services-level storage driver (used by image/video generation services)
STORAGE_DRIVER=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_S3_BASE_FOLDER=images
AWS_URL=
CLOUDFRONT_DOMAIN=d1i8qg2rdfk1rg.cloudfront.net

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ─── AI Providers ─────────────────────────────────────────────────────────────
DEFAULT_AI_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Gemini / Google
GEMINI_API_KEY=
GEMINI_MODEL=

# Qwen / DashScope (Alibaba) — DASHSCOPE_API_KEY is the key services.php reads
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-max

# MiniMax
MINIMAX_API_KEY=
MINIMAX_MODEL=minimax-01

# ─── Credits ──────────────────────────────────────────────────────────────────
INITIAL_CREDITS=50
IMAGE_COST_CREDITS=10
IMAGE_COST_CREDITS_GEMINI=20

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ─── reCAPTCHA ────────────────────────────────────────────────────────────────
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── pgAdmin (Docker UI only) ─────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ─── Mongo Express (Docker UI only) ───────────────────────────────────────────
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin
